{
  "crons": [
    {
      "path": "/api/cron/publish",
      "schedule": "0 1 * * *"
    },
    {
      "path": "/api/cron/social-queue",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/media-production",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/content-factory",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/backup",
      "schedule": "30 1 * * *"
    },
    {
      "path": "/api/cron/ops-digest",
      "schedule": "0 2 * * 1"
    },
    {
      "path": "/api/cron/evergreen",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/cron/stale-content",
      "schedule": "0 3 * * 2"
    },
    {
      "path": "/api/cron/newsletter",
      "schedule": "0 2 * * 4"
    },
    {
      "path": "/api/cron/newsletter-drip",
      "schedule": "0 5 * * *"
    },
    {
      "path": "/api/cron/platform-metrics",
      "schedule": "0 */6 * * *"
    }
  ],
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "thinkbizlab.com" }],
      "destination": "https://www.thinkbizlab.com/:path*",
      "permanent": true
    }
  ]
}
