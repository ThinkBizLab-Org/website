# Copy this file to .env.local and fill in your values

# ─── Database ───────────────────────────────────────────────
# Neon PostgreSQL — get from console.neon.tech
DATABASE_URL="postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require"

# ─── Site ───────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL="https://thinkbizlab.com"

# ─── Auth (NextAuth + Google) ───────────────────────────────
# 1. Go to https://console.cloud.google.com → APIs & Services → Credentials
# 2. Create OAuth 2.0 Client → Web Application
# 3. Add Authorized redirect URI: https://your-domain.com/api/auth/callback/google
GOOGLE_CLIENT_ID="xxx.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="GOCSPX-xxx"

# Random secret: run `openssl rand -base64 32`
NEXTAUTH_SECRET="your-random-secret-here"
NEXTAUTH_URL="https://thinkbizlab.com"

# Random 32-byte secret for encrypting API keys stored in DB settings.
# Generate with: openssl rand -base64 32
ENCRYPTION_KEY="your-32-byte-base64-secret"

# Optional. Defaults to NEXTAUTH_SECRET if omitted.
PREVIEW_TOKEN_SECRET="your-preview-token-secret"

# Comma-separated Gmail addresses allowed to access /admin
# Leave empty to allow ANY Google account (dev only)
ADMIN_EMAILS="your@gmail.com"

# ─── Cloudflare R2 Media Storage ────────────────────────────
# R2 is S3-compatible. Create an R2 bucket and API token in Cloudflare.
R2_ACCOUNT_ID="your-cloudflare-account-id"
R2_ACCESS_KEY_ID="your-r2-access-key-id"
R2_SECRET_ACCESS_KEY="your-r2-secret-access-key"
R2_BUCKET_NAME="thinkbiz-media"

# Public custom domain or r2.dev URL without trailing slash.
# Example: https://media.thinkbizlab.com
R2_PUBLIC_BASE_URL="https://media.thinkbizlab.com"

# ─── Email (Resend) — newsletter + opt-in confirmation ──────
# Required for subscribers to receive the double opt-in confirmation email.
# Can also be saved in DB settings (resend_api_key / notify_email_from).
RESEND_API_KEY="re_xxx"
NOTIFY_EMAIL_FROM="ThinkBiz Lab <hello@thinkbizlab.com>"

# ─── Email capture (public, optional) ───────────────────────
# LINE OA follow link shown beside email forms (defaults to @thinkbizlab).
NEXT_PUBLIC_LINE_OA_URL="https://line.me/R/ti/p/@thinkbizlab"
# Lead magnet on the homepage — set the URL to enable the section.
NEXT_PUBLIC_LEAD_MAGNET_URL=""
NEXT_PUBLIC_LEAD_MAGNET_TITLE=""
NEXT_PUBLIC_LEAD_MAGNET_DESC=""

# ─── Cron ───────────────────────────────────────────────────
# Optional but recommended in production.
CRON_SECRET="your-cron-secret"

# Optional operational alert webhook for cron/API failures.
# Can point to Slack, Discord, Logtail, Make, or any JSON webhook receiver.
ERROR_WEBHOOK_URL="https://example.com/webhook"

# ─── AI / Media Generation ─────────────────────────────────
# These can also be saved from /admin/settings.
ANTHROPIC_API_KEY="sk-ant-xxx"
FAL_KEY="fal-xxx"
HEYGEN_API_KEY="heygen-xxx"
HEYGEN_AVATAR_ID="avatar-id"
HEYGEN_AVATAR_LOOK_ID="avatar-look-id"
HEYGEN_VOICE_ID="voice-id"

# ─── LINE ──────────────────────────────────────────────────
LINE_CHANNEL_ACCESS_TOKEN="line-channel-access-token"
LINE_CHANNEL_SECRET="line-channel-secret"
LINE_ADMIN_USER_IDS="line-user-id-1,line-user-id-2"

# ─── Facebook / Instagram ──────────────────────────────────
# These can also be saved from /admin/settings.
FB_PAGE_ACCESS_TOKEN="facebook-page-access-token"
FB_PAGE_ID="facebook-page-id"
IG_USER_ID="instagram-business-user-id"

# ─── TikTok OAuth ───────────────────────────────────────────
TIKTOK_CLIENT_KEY="your-tiktok-client-key"
TIKTOK_CLIENT_SECRET="your-tiktok-client-secret"
TIKTOK_REDIRECT_URI="https://www.thinkbizlab.com/api/auth/tiktok/callback"

# ─── Hybrid video pipeline (Remotion on AWS Lambda) ─────────
# Only needed when video_pipeline.engine = "remotion" and the flag is enabled.
# Deploy remotion/ first (cd remotion && node deploy.mjs) — it prints these.
REMOTION_AWS_REGION="us-east-1"
REMOTION_FUNCTION_NAME="remotion-render-4-0-x-mem2048mb-..."
REMOTION_SERVE_URL="https://remotionlambda-xxx.s3.../sites/thinkbiz-shortvideo/index.html"
REMOTION_COMPOSITION_ID="ShortVideo"
# IAM user creds the app uses to invoke the render Lambda at runtime.
AWS_ACCESS_KEY_ID="your-aws-access-key-id"
AWS_SECRET_ACCESS_KEY="your-aws-secret-access-key"

# ElevenLabs TTS (Thai voiceover) — set via Admin → Settings (stored encrypted),
# NOT via env. Listed here for reference only:
#   elevenlabs_api_key, elevenlabs_voice_id
